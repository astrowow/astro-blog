    "@sanity/image-url": "^2.0.3",
    "@sanity/preview-url-secret": "^4.0.3",
    "@sanity/vision": "^5.16.0",
    "@sanity/visual-editing": "^5.3.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
